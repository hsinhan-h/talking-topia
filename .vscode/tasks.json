{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build: Api",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/Api/Api.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "problemMatcher": "$msCompile",
            "group": "build"
        },
        {
            "label": "watch: Api",
            "command": "dotnet",
            "type": "process",
            "args": [
                "watch",
                "--project",
                "${workspaceFolder}/Api/Api.csproj",
                "--non-interactive",
                "run",
                "--no-restore"
            ],
            "problemMatcher": {
                "base": "$msCompile",
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "dotnet watch|Building",
                    "endsPattern": "Now listening on:|Application started|dotnet watch .*Started"
                }
            },
            "isBackground": true,
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "group": "watchers"
            },
            "options": {
                "env": {
                    "ASPNETCORE_ENVIRONMENT": "Development",
                    "ASPNETCORE_URLS": "https://localhost:7204;http://localhost:5036",
                    "DOTNET_WATCH_RESTART_ON_RUDE_EDIT": "1",
                    "DOTNET_WATCH_SUPPRESS_EMOJIS": "1"
                }
            }
        },
        {
            "label": "build: Web",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/Web/Web.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "problemMatcher": "$msCompile",
            "group": "build"
        },
        {
            "label": "watch: Web",
            "command": "dotnet",
            "type": "process",
            "args": [
                "watch",
                "--project",
                "${workspaceFolder}/Web/Web.csproj",
                "--non-interactive",
                "run",
                "--no-restore"
            ],
            "problemMatcher": {
                "base": "$msCompile",
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "dotnet watch|Building",
                    "endsPattern": "Now listening on:|Application started|dotnet watch .*Started"
                }
            },
            "isBackground": true,
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "group": "watchers"
            },
            "options": {
                "env": {
                    "ASPNETCORE_ENVIRONMENT": "Development",
                    "ASPNETCORE_URLS": "https://localhost:7263;http://localhost:5180",
                    "DOTNET_WATCH_RESTART_ON_RUDE_EDIT": "1",
                    "DOTNET_WATCH_SUPPRESS_EMOJIS": "1"
                }
            }
        },
        {
            "label": "build: solution",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/TalkingTopia.sln",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "problemMatcher": "$msCompile",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}
